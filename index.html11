const logger = {
  info: (message) => {
    console.log(`[${new Date().toISOString()}] ℹ️ ${message}`);
  },
  error: (message, error) => {
    console.error(`[${new Date().toISOString()}] ❌ ${message}`, error || '');
  },
  warn: (message) => {
    console.warn(`[${new Date().toISOString()}] ⚠️ ${message}`);
  }
};

module.exports = logger;
